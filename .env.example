# Environment Variables Example
# Copy this file to .env.local for development
# For production on Vercel, add these in Project Settings > Environment Variables

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Tailwind Practice"

# Database (SQLite for development)
# For production, consider PostgreSQL or MySQL on Vercel
DATABASE_URL=file:./src/db/portfolio.db

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: CMS or External APIs
# CONTENT_API_URL=https://your-api.com
# CONTENT_API_KEY=your-api-key

# Optional: Email Service (for contact form)
# EMAIL_SERVER_HOST=smtp.gmail.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=your-email@gmail.com
# EMAIL_SERVER_PASSWORD=your-app-password
# EMAIL_FROM=your-email@gmail.com
